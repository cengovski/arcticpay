# Arctic Pay DApp — Environment Variables Template
# Copy to .env.local and fill in your values
# NEVER commit .env.local to git!

# ── Circle API (required for CCTP + Iris) ──
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_ENTITY_SECRET=your_entity_secret_here

# ── Circle App Kit (public, required for wallet connection) ──
NEXT_PUBLIC_CIRCLE_APP_KIT_KEY=your_app_kit_key_here

# ── Solana RPC (Helius recommended for Devnet) ──
NEXT_PUBLIC_SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ── Solana USDC Mint (Devnet, Circle test USDC) ──
NEXT_PUBLIC_SOLANA_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ── ARC Testnet ──
NEXT_PUBLIC_ARC_TESTNET_RPC=https://rpc-testnet.arctium.io
NEXT_PUBLIC_ARC_TESTNET_CHAIN_ID=11111

# ── Ethereum Sepolia (optional) ──
NEXT_PUBLIC_SEPOLIA_RPC=https://sepolia.infura.io/v3/YOUR_KEY
